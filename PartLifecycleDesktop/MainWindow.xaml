<Window x:Class="PartLifecycleDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Part Lifecycle Analyzer"
        Height="760"
        Width="1240"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F2EC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Margin="20" Padding="24" CornerRadius="20" Background="#17302B">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.6*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Grid Margin="0,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="220"
                            Height="80"
                            VerticalAlignment="Top"
                            Background="#FFF8ED"
                            CornerRadius="16"
                            Padding="10">
                        <Image Source="Assets/company-badge.jpg"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Part Lifecycle Analyzer"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF8ED"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="Paste one part number per line. The app checks distributor and manufacturer pages, estimates lifecycle status, captures manufacturer names, and lets you export the results to Excel."
                                   Foreground="#D6E5DF"
                                   TextWrapping="Wrap"
                                   FontSize="14"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Column="1"
                        Padding="18"
                        CornerRadius="16"
                        Background="#23423B">
                    <StackPanel>
                        <TextBlock Text="Input Format"
                                   Foreground="#FFF8ED"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="Example:"
                                   Foreground="#D6E5DF"/>
                        <TextBlock Margin="0,8,0,0"
                                   FontFamily="Consolas"
                                   Foreground="#FFF8ED"
                                   Text="LT1129CQ-5#PBF&#10;TSZ122IST&#10;ADP151AUJZ-1.8-R7"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="18" Background="White" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Part Numbers"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#17302B"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="One part per line."
                                   Foreground="#526560"/>
                    </StackPanel>

                    <TextBox x:Name="PartNumbersTextBox"
                             Grid.Row="1"
                             Margin="0,16,0,16"
                             Padding="12"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="14"/>

                    <StackPanel Grid.Row="2">
                        <Button x:Name="AnalyzeButton"
                                Height="42"
                                Margin="0,0,0,10"
                                Click="AnalyzeButton_Click"
                                Background="#C96D42"
                                Foreground="White"
                                BorderBrush="#C96D42"
                                FontWeight="SemiBold"
                                Content="Analyze Parts"/>
                        <Button x:Name="AbortButton"
                                Height="42"
                                Margin="0,0,0,10"
                                Click="AbortButton_Click"
                                Background="#A63A3A"
                                Foreground="White"
                                BorderBrush="#A63A3A"
                                FontWeight="SemiBold"
                                Content="Abort Analysis"
                                IsEnabled="False"/>
                        <Button x:Name="ExportButton"
                                Height="42"
                                Click="ExportButton_Click"
                                Background="#E8ECEB"
                                Foreground="#17302B"
                                BorderBrush="#D5DDDA"
                                FontWeight="SemiBold"
                                Content="Export to Excel"
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="18" Background="White" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Results"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#17302B"/>
                        <TextBlock x:Name="ResultCountTextBlock"
                                   Margin="12,2,0,0"
                                   Foreground="#526560"/>
                    </StackPanel>

                    <DataGrid x:Name="ResultsGrid"
                              Grid.Row="1"
                              Margin="0,16,0,16"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="ResultsGrid_SelectionChanged"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="1.3*"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="1.2*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding OverallStatus}" Width="0.8*"/>
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="2.0*"/>
                            <DataGridTextColumn Header="Evidence" Binding="{Binding EvidencePreview}" Width="1.6*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="#F7F7F5"
                            CornerRadius="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="DetailsTextBlock"
                                       Text="Select a result to see detailed source evidence."
                                       TextWrapping="Wrap"
                                       Foreground="#31413D"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="20,0,20,20" Padding="14,10" CornerRadius="14" Background="#E3EBE7">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#17302B"
                       Text="Ready."/>
        </Border>
    </Grid>
</Window>
